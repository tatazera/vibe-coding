# ── Domínio do servidor ────────────────────────────────────────────────────────
# Ex: projetos.stand1.com.br  (sem https://)
DOMAIN=projetos.stand1.com.br

# ── PostgreSQL (banco interno do n8n) ──────────────────────────────────────────
PG_DB=n8n
PG_USER=n8n
PG_PASS=troque_esta_senha_pg

# ── n8n ────────────────────────────────────────────────────────────────────────
N8N_KEY=troque_esta_chave_enc_32chars
N8N_USER=admin
N8N_PASS=troque_esta_senha_n8n

# ── Evolution API (chave de autenticação das chamadas) ────────────────────────
EVOLUTION_KEY=troque_esta_chave_evolution

# ── Bridge (token que o n8n usa ao fazer POST para o bridge) ──────────────────
# Esse mesmo token deve ser colocado no campo "Token" do modal de config do dashboard
BRIDGE_TOKEN=troque_este_token_bridge

# ── Claude API (usado no workflow n8n para extrair dados das mensagens) ────────
ANTHROPIC_API_KEY=sk-ant-xxxxx
